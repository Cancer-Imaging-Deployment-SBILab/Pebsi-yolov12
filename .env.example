# =============================================================================
# PEBSI YOLOV12 SERVICE - ENVIRONMENT TEMPLATE
# Copy to `.env` and replace placeholders.
# =============================================================================

# PostgreSQL URL used by SQLAlchemy async engine.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
URL_DATABASE=postgresql+asyncpg://postgres:change-me@localhost:5432/pebsi

# Base storage directory shared with backend and other model services.
BASE_DIR=/path/to/base/dir

# Service identity and bind settings.
SERVICE_NAME=yolov12
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001
# Set true for development hot reload only.
SERVICE_REFRESH=false

# CA cert used to validate client certs.
SSL_CA_FILE=/certs/ca/ca.crt
# Server certificate presented by this service.
SSL_CERT_FILE=/certs/yolov12/server.crt
# Private key for `SSL_CERT_FILE`.
SSL_KEY_FILE=/certs/yolov12/server.key

# -----------------------------------------------------------------------------
# Internal service-to-service JWT (2nd layer, alongside mTLS)
# -----------------------------------------------------------------------------
INTERNAL_JWT_SECRET=replace-with-same-internal-secret-as-backend
INTERNAL_JWT_ISSUER=pebsi-backend
INTERNAL_JWT_AUDIENCE=pebsi-internal
INTERNAL_JWT_ALGORITHM=HS256

# Comma-separated user-agent keywords to block.
SECURITY_BLOCKED_USER_AGENTS=httpx,postman,wget,insomnia,libwww,java